---
apiVersion: kuttl.dev/v1beta1
kind: TestStep
metadata:
  name: druid-hdfs
timeout: 600
---
apiVersion: hdfs.stackable.tech/v1alpha1
kind: HdfsCluster
metadata:
  name: druid-hdfs
spec:
  image:
    productVersion: "{{ test_scenario['values']['hadoop'] }}"
    pullPolicy: IfNotPresent
  clusterConfig:
    dfsReplication: 1
{% if lookup('env', 'VECTOR_AGGREGATOR') %}
    vectorAggregatorConfigMapName: vector-aggregator-discovery
{% endif %}
    zookeeperConfigMapName: hdfs-znode
  nameNodes:
    config:
      resources:
        cpu:
          min: 50m
          max: 500m
        memory:
          limit: 256Mi
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        replicas: 2
  dataNodes:
    config:
      resources:
        cpu:
          min: 50m
          max: 500m
        memory:
          limit: 256Mi
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        replicas: 1
  journalNodes:
    config:
      resources:
        cpu:
          min: 50m
          max: 500m
        memory:
          limit: 192Mi
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        replicas: 1
