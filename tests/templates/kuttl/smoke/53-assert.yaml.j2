      expected=$(cat <<'YAMLEOF' | sed "s|__NAMESPACE__|$NAMESPACE|g" | yq -o=json
      jvm.config: |-
        -server
        -Xmx800m
        -Xms800m
        -XX:MaxDirectMemorySize=400m
        -XX:+ExitOnOutOfMemoryError
        -XX:+UseG1GC
        -Djava.security.properties=/stackable/rwconfig/security.properties
        -Duser.timezone=UTC
        -Dfile.encoding=UTF-8
        -Djava.io.tmpdir=/tmp
        -Djava.util.logging.manager=org.apache.logging.log4j.jul.LogManager
        -Dlog4j.configurationFile=/stackable/rwconfig/log4j2.properties
