# ----- ClusterIP Services (broker / coordinator / router) -----
# These are owned by the Listener (not DruidCluster), so ownerReferences are
# intentionally omitted here to avoid false-negative subset-match failures.
apiVersion: v1
kind: Service
metadata:
  name: druid-broker
spec:
  ports:
    - name: https
      port: 8282
      protocol: TCP
      targetPort: 8282
  type: ClusterIP
---
apiVersion: v1
kind: Service
metadata:
  name: druid-coordinator
spec:
  ports:
    - name: https
      port: 8281
      protocol: TCP
      targetPort: 8281
  type: ClusterIP
---
apiVersion: v1
kind: Service
metadata:
  name: druid-router
spec:
  ports:
    - name: https
      port: 9088
      protocol: TCP
      targetPort: 9088
  type: ClusterIP
---
